generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Usuario {
  id        Int       @id @default(autoincrement())
  username  String    @unique
  password  String?
  progreso  Progreso?
}

model Progreso {
  id           Int     @id @default(autoincrement())
  comunicacion Int     @default(0)
  empleo       Int     @default(0)
  ideas        Int     @default(0)
  
  usuarioId    Int     @unique
  usuario      Usuario @relation(fields: [usuarioId], references: [id])
}
